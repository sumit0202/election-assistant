# =============================================================
# Election Process Education Assistant — environment template
# Copy this to `.env` and fill in real values. Never commit `.env`.
# =============================================================

# --- Core ---
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:8080

# --- Google AI / Gemini ---
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Google Maps Platform (Places + Geocoding) ---
GOOGLE_MAPS_API_KEY=replace-with-your-maps-key

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=replace-with-your-youtube-key

# --- Google Cloud Translate (uses ADC; set project) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
TRANSLATE_LOCATION=global

# --- Calendar (we generate ICS – no key required) ---
DEFAULT_TIMEZONE=Asia/Kolkata

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30
