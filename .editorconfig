# EditorConfig — keep style consistent across IDEs / editors.
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 100

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false  # Markdown uses two trailing spaces for <br>

[*.{yml,yaml,json,toml}]
indent_size = 2
